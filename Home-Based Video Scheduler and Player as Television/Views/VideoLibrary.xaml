<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.VideoLibrary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Library" Height="540" Width="820"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="VIDEO LIBRARY"
                   Foreground="White" FontSize="28" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="+ Add Files"
                    Command="{Binding AddFilesCommand}"
                    Background="#378ADD" Foreground="White"
                    BorderThickness="0" Padding="12,6" FontSize="13"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="+ Add Folder"
                    Command="{Binding AddFolderCommand}"
                    Background="#2A6A2A" Foreground="White"
                    BorderThickness="0" Padding="12,6" FontSize="13"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Remove Selected"
                    Command="{Binding RemoveVideoCommand}"
                    IsEnabled="{Binding SelectedVideo,
                                Converter={StaticResource NullToBoolConverter}}"
                    Background="#CC3333" Foreground="White"
                    BorderThickness="0" Padding="12,6" FontSize="13"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Video list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Videos}"
                  SelectedItem="{Binding SelectedVideo, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True"
                  RowHeight="34" FontSize="13"
                  BorderThickness="1" BorderBrush="#2A2A3A">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Title"
                                    Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Duration"
                                    Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}"
                                    Width="100"/>
                <DataGridTextColumn Header="File Path"
                                    Binding="{Binding FilePath}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       Foreground="#9999AA" FontSize="12"
                       VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1"
                         IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                         Width="120" Height="6"/>
        </Grid>
    </Grid>
</Window>
