<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.CommercialBreakView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commercial Breaks" Height="680" Width="960"
        Background="#FF0D0D14">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentRed"   Color="#E8312A"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#F0A500"/>
        <SolidColorBrush x:Key="CardBg"      Color="#161622"/>
        <SolidColorBrush x:Key="CardBorder"  Color="#2A2A3A"/>
        <SolidColorBrush x:Key="DimText"     Color="#555566"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="COMMERCIAL BREAK EDITOR"
                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                       Foreground="#E8312A" Margin="0,0,0,6"/>
            <TextBlock Text="Visual Timeline"
                       FontFamily="Consolas" FontSize="24" FontWeight="Bold"
                       Foreground="White"/>
        </StackPanel>

        <!-- Show selector + info -->
        <Border Grid.Row="1" Background="#161622" BorderBrush="#2A2A3A"
                BorderThickness="1" CornerRadius="6" Padding="16,12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SELECT SHOW" FontFamily="Consolas" FontSize="10"
                               Foreground="#9999AA" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Shows}"
                              SelectedItem="{Binding SelectedShow}"
                              DisplayMemberPath="EffectiveTitle"
                              FontSize="14" FontFamily="Consolas"
                              Background="#1E1E2E" Foreground="White"
                              BorderBrush="#2A2A3A"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            Margin="20,0,0,0" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ShowDurationLabel}"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Right"/>
                    <TextBlock Text="DURATION" FontFamily="Consolas" FontSize="10"
                               Foreground="#9999AA" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── VISUAL TIMELINE ──────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#161622" BorderBrush="#2A2A3A"
                BorderThickness="1" CornerRadius="6" Padding="16,14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="TIMELINE" FontFamily="Consolas" FontSize="10"
                           Foreground="#9999AA" Margin="0,0,0,10"/>

                <!-- Track container — code-behind draws markers on top of the bar -->
                <Grid Height="52">
                    <!-- Background track -->
                    <Border Height="12" VerticalAlignment="Center"
                            Background="#0D0D1A" CornerRadius="6"
                            BorderBrush="#2A2A3A" BorderThickness="1"/>

                    <!-- Progress fill (show start to end = full) -->
                    <Border Height="12" VerticalAlignment="Center"
                            HorizontalAlignment="Left" Width="0"
                            CornerRadius="6" x:Name="TrackFill"
                            Background="#1E3A1E"/>

                    <!-- Marker canvas — populated in code-behind -->
                    <Canvas x:Name="TimelineCanvas" Height="52"/>
                </Grid>

                <!-- Time labels row — code-behind populates -->
                <Canvas x:Name="TimeLabelCanvas" Height="18" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Add break controls -->
        <Border Grid.Row="3" Background="#161622" BorderBrush="#2A2A3A"
                BorderThickness="1" CornerRadius="6" Padding="16,12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="COMMERCIAL" FontFamily="Consolas" FontSize="10"
                               Foreground="#9999AA" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Commercials}"
                              SelectedItem="{Binding SelectedCommercial}"
                              DisplayMemberPath="Title"
                              FontSize="13" Background="#1E1E2E"
                              Foreground="White" BorderBrush="#2A2A3A"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="INSERT AT (HH:MM:SS)" FontFamily="Consolas"
                               FontSize="10" Foreground="#9999AA" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding OffsetText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" FontFamily="Consolas"
                             Background="#1E1E2E" Foreground="White"
                             BorderBrush="#2A2A3A" Padding="6,4"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                    <Button Content="+ ADD BREAK"
                            Command="{Binding AddBreakCommand}"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Background="#E8312A" Foreground="White"
                            BorderThickness="0" Padding="16,8" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Breaks list -->
        <Border Grid.Row="4" Background="#161622" BorderBrush="#2A2A3A"
                BorderThickness="1" CornerRadius="6" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="BREAK LIST"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#9999AA" Margin="0,0,0,10"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding BreaksForShow}"
                              x:Name="BreakList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A2A" BorderBrush="#2A2A3A"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="12,8" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Time marker -->
                                    <Border Grid.Column="0" Background="#2A0A0A"
                                            CornerRadius="3" Padding="8,4"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="{Binding OffsetDisplay}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   FontWeight="Bold" Foreground="#E8312A"/>
                                    </Border>

                                    <!-- Commercial name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CommercialTitle}"
                                               FontFamily="Consolas" FontSize="13"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>

                                    <!-- Ad icon -->
                                    <TextBlock Grid.Column="2" Text="📢"
                                               FontSize="14" Foreground="#F0A500"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Grid.Row="2"
                        Content="REMOVE SELECTED"
                        Command="{Binding RemoveBreakCommand}"
                        IsEnabled="{Binding SelectedBreak,
                                    Converter={StaticResource NullToBoolConverter}}"
                        FontFamily="Consolas" FontSize="11"
                        Background="#2A0A0A" Foreground="#E8312A"
                        BorderBrush="#E8312A" BorderThickness="1"
                        Padding="12,6" Cursor="Hand"
                        HorizontalAlignment="Left" Margin="0,10,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
