<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.Schedule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Home_Based_Video_Scheduler_and_Player_as_Television.ViewModels"
        Title="Schedule Manager"
        Height="600" Width="1000"
        Background="{StaticResource BackgroundColor}">

    <Window.DataContext>
        <vm:ScheduleViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ADD SCHEDULE CONTROLS -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,20">
            <TextBlock Text="Video:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
            <ComboBox ItemsSource="{Binding Videos}" 
                      SelectedItem="{Binding SelectedVideo}" 
                      DisplayMemberPath="Title"
                      Width="300"/>

            <TextBlock Text="Start Time:" VerticalAlignment="Center" Margin="20,0,10,0" Foreground="White"/>
            <DatePicker SelectedDate="{Binding StartTime}" Width="150"/>
            <TextBox Text="{Binding StartTime, StringFormat=HH:mm}" Width="80" Margin="5,0,0,0"/>

            <Button Content="Add" Command="{Binding AddScheduleCommand}" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- SCHEDULE DATA GRID -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Schedule}"
                  SelectedItem="{Binding SelectedScheduleItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Background="White"
                  Foreground="Black"
                  FontSize="16"
                  Margin="0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Video" Binding="{Binding VideoTitle}" Width="*"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat=MM/dd/yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="End Time" Binding="{Binding EndTime, StringFormat=MM/dd/yyyy HH:mm}" Width="150"/>
            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Remove" Command="{Binding DataContext.RemoveScheduleCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Window>