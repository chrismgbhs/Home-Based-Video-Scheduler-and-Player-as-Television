<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Home-Based Video Scheduler and Player as Television"
        WindowState="Maximized"
        Background="#FF0D0D14">

    <Window.Resources>
        <!-- Broadcast red accent -->
        <SolidColorBrush x:Key="AccentRed"    Color="#E8312A"/>
        <SolidColorBrush x:Key="AccentAmber"  Color="#F0A500"/>
        <SolidColorBrush x:Key="DimText"      Color="#666677"/>
        <SolidColorBrush x:Key="CardBg"       Color="#161622"/>
        <SolidColorBrush x:Key="CardBorder"   Color="#2A2A3A"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"   Value="#161622"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="15"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="20,0,20,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E2E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E8312A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8312A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL ─────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0D0D14"
                BorderBrush="#1A1A28" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Station logo / title area -->
                <StackPanel Grid.Row="0" Margin="28,40,28,32">
                    <TextBlock Text="⬛ ON AIR"
                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#E8312A"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="HOME TV"
                               FontFamily="Consolas" FontSize="36" FontWeight="Bold"
                               Foreground="White" LineHeight="38"/>
                    <TextBlock Text="BROADCAST CONTROL"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="#666677"
                               Margin="0,4,0,0"/>
                    <Rectangle Height="1" Fill="#E8312A" Margin="0,20,0,0" Opacity="0.6"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1" Margin="20,0,20,0">

                    <TextBlock Text="PLAYBACK" FontFamily="Consolas" FontSize="10"
                               Foreground="#888899" Margin="8,0,0,8"/>

                    <Button Height="52" Margin="0,0,0,4"
                            Command="{Binding ViewPlayerCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Foreground="#E8312A"
                                           FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Video Player" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Open broadcast view" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Height="52" Margin="0,0,0,16"
                            Command="{Binding SchedulerCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Schedule" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Manage show lineup" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <TextBlock Text="LIBRARY" FontFamily="Consolas" FontSize="10"
                               Foreground="#888899" Margin="8,0,0,8"/>

                    <Button Height="52" Margin="0,0,0,4"
                            Command="{Binding VideoLibraryCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎬" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Video Library" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Add and manage videos" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Height="52" Margin="0,0,0,4"
                            Command="{Binding CommercialLibraryCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📢" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Commercial Library" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Manage ad clips" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Height="52" Margin="0,0,0,16"
                            Command="{Binding CommercialBreakCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏸" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Commercial Breaks" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Set ad insertion points" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <TextBlock Text="SYSTEM" FontFamily="Consolas" FontSize="10"
                               Foreground="#888899" Margin="8,0,0,8"/>

                    <Button Height="52" Margin="0,0,0,4"
                            Command="{Binding SettingsCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Settings" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Logo, overlays, preferences" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- Bottom version tag -->
                <TextBlock Grid.Row="2"
                           Text="HOME-BASED TV  v1.0"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#666677"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
            </Grid>
        </Border>

        <!-- ── RIGHT PANEL — info / splash ───────────────────────────────── -->
        <Grid Grid.Column="1" Background="#0D0D14">

            <!-- Subtle grid texture lines -->
            <Canvas>
                <Line X1="0" Y1="200"  X2="2000" Y2="200"  Stroke="#111120" StrokeThickness="1"/>
                <Line X1="0" Y1="400"  X2="2000" Y2="400"  Stroke="#111120" StrokeThickness="1"/>
                <Line X1="0" Y1="600"  X2="2000" Y2="600"  Stroke="#111120" StrokeThickness="1"/>
                <Line X1="200"  Y1="0" X2="200"  Y2="1200" Stroke="#111120" StrokeThickness="1"/>
                <Line X1="400"  Y1="0" X2="400"  Y2="1200" Stroke="#111120" StrokeThickness="1"/>
                <Line X1="600"  Y1="0" X2="600"  Y2="1200" Stroke="#111120" StrokeThickness="1"/>
                <Line X1="800"  Y1="0" X2="800"  Y2="1200" Stroke="#111120" StrokeThickness="1"/>
                <Line X1="1000" Y1="0" X2="1000" Y2="1200" Stroke="#111120" StrokeThickness="1"/>
            </Canvas>

            <!-- Center content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="STATION CONTROL"
                           FontFamily="Consolas" FontSize="13"
                           Foreground="#666677"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Big signal icon -->
                <Border Width="160" Height="160"
                        BorderBrush="#1A1A28" BorderThickness="1"
                        CornerRadius="80"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#1A0808" Offset="0"/>
                            <GradientStop Color="#0D0D14" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                    <TextBlock Text="📡" FontSize="64"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Select an option from the menu"
                           FontFamily="Consolas" FontSize="14"
                           Foreground="#666677"
                           HorizontalAlignment="Center"/>

                <!-- Quick stat cards -->
                <StackPanel Orientation="Horizontal" Margin="0,48,0,0"
                            HorizontalAlignment="Center">
                    <Border Background="#161622" BorderBrush="#2A2A3A"
                            BorderThickness="1" CornerRadius="6"
                            Padding="24,16" Margin="6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ScheduledCount}"
                                       FontFamily="Consolas" FontSize="28"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="SCHEDULED" FontFamily="Consolas"
                                       FontSize="10" Foreground="#888899"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#161622" BorderBrush="#2A2A3A"
                            BorderThickness="1" CornerRadius="6"
                            Padding="24,16" Margin="6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding VideoCount}"
                                       FontFamily="Consolas" FontSize="28"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="VIDEOS" FontFamily="Consolas"
                                       FontSize="10" Foreground="#888899"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#161622" BorderBrush="#2A2A3A"
                            BorderThickness="1" CornerRadius="6"
                            Padding="24,16" Margin="6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CommercialCount}"
                                       FontFamily="Consolas" FontSize="28"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="ADS" FontFamily="Consolas"
                                       FontSize="10" Foreground="#888899"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
