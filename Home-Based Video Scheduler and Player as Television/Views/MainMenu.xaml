<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Home-Based Video Scheduler and Player as Television"
        WindowState="Maximized"
        Background="#FF0D0D14">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentRed"   Color="#E8312A"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#F0A500"/>
        <SolidColorBrush x:Key="CardBg"      Color="#161622"/>
        <SolidColorBrush x:Key="CardBorder"  Color="#2A2A3A"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Invert bool converter inline via style trigger -->

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"      Value="#161622"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="20,0,20,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E2E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E8312A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8312A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Show card style — highlighted red if currently airing -->
        <Style x:Key="ShowCard" TargetType="Border">
            <Setter Property="Background"      Value="#161622"/>
            <Setter Property="BorderBrush"     Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="14,10"/>
            <Setter Property="Margin"          Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL ────────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0D0D14"
                BorderBrush="#1A1A28" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,36,24,28">
                    <TextBlock Text="⬛ ON AIR" FontFamily="Consolas" FontSize="11"
                               FontWeight="Bold" Foreground="#E8312A" Margin="0,0,0,14"/>
                    <TextBlock Text="HOME TV" FontFamily="Consolas" FontSize="34"
                               FontWeight="Bold" Foreground="White" LineHeight="36"/>
                    <TextBlock Text="BROADCAST CONTROL" FontFamily="Consolas" FontSize="11"
                               Foreground="#666677" Margin="0,4,0,0"/>
                    <Rectangle Height="1" Fill="#E8312A" Margin="0,18,0,0" Opacity="0.6"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="16,0,16,0">
                    <TextBlock Text="PLAYBACK" FontFamily="Consolas" FontSize="10"
                               Foreground="#888899" Margin="8,0,0,8"/>
                    <Button Height="52" Margin="0,0,0,4" Command="{Binding ViewPlayerCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Foreground="#E8312A" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Video Player" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Open broadcast view" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Height="52" Margin="0,0,0,16" Command="{Binding SchedulerCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Schedule" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Manage show lineup" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <TextBlock Text="LIBRARY" FontFamily="Consolas" FontSize="10"
                               Foreground="#888899" Margin="8,0,0,8"/>
                    <Button Height="52" Margin="0,0,0,4" Command="{Binding VideoLibraryCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎬" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Video Library" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Add and manage videos" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Height="52" Margin="0,0,0,4" Command="{Binding CommercialLibraryCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📢" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Commercial Library" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Manage ad clips" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Height="52" Margin="0,0,0,16" Command="{Binding CommercialBreakCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏸" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Commercial Breaks" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Set ad insertion points" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <TextBlock Text="SYSTEM" FontFamily="Consolas" FontSize="10"
                               Foreground="#888899" Margin="8,0,0,8"/>
                    <Button Height="52" Margin="0,0,0,4" Command="{Binding SettingsCommand}"
                            Style="{StaticResource NavButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="Settings" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="Logo, overlays, preferences" FontSize="10" Foreground="#666677"/>
                                </StackPanel>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="HOME-BASED TV  v1.0"
                           FontFamily="Consolas" FontSize="10" Foreground="#333344"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
            </Grid>
        </Border>

        <!-- ── RIGHT PANEL — schedule dashboard ──────────────────────────────── -->
        <Grid Grid.Column="1" Background="#0D0D14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0D0D14"
                    BorderBrush="#1A1A28" BorderThickness="0,0,0,1"
                    Padding="28,20,28,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BROADCAST SCHEDULE" FontFamily="Consolas"
                                   FontSize="11" Foreground="#E8312A" Margin="0,0,0,4"/>
                        <TextBlock Text="Full Programme Listing"
                                   FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>

                    <!-- Stat pills -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#161622" BorderBrush="#2A2A3A"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,8" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ScheduledCount}"
                                           FontFamily="Consolas" FontSize="18"
                                           FontWeight="Bold" Foreground="White"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="SHOWS" FontFamily="Consolas"
                                           FontSize="10" Foreground="#888899"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#161622" BorderBrush="#2A2A3A"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,8" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding VideoCount}"
                                           FontFamily="Consolas" FontSize="18"
                                           FontWeight="Bold" Foreground="White"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="VIDEOS" FontFamily="Consolas"
                                           FontSize="10" Foreground="#888899"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#161622" BorderBrush="#2A2A3A"
                                BorderThickness="1" CornerRadius="4"
                                Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CommercialCount}"
                                           FontFamily="Consolas" FontSize="18"
                                           FontWeight="Bold" Foreground="White"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="ADS" FontFamily="Consolas"
                                           FontSize="10" Foreground="#888899"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Column headers -->
            <Grid Grid.Row="1" Margin="28,14,28,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TIME" FontFamily="Consolas"
                           FontSize="10" Foreground="#555566"/>
                <TextBlock Grid.Column="1" Text="TITLE" FontFamily="Consolas"
                           FontSize="10" Foreground="#555566"/>
                <TextBlock Grid.Column="2" Text="SHOW DUR" FontFamily="Consolas"
                           FontSize="10" Foreground="#555566"/>
                <TextBlock Grid.Column="3" Text="AD TIME" FontFamily="Consolas"
                           FontSize="10" Foreground="#555566"/>
                <TextBlock Grid.Column="4" Text="TRUE END" FontFamily="Consolas"
                           FontSize="10" Foreground="#555566"/>
            </Grid>

            <!-- Schedule list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Margin="0,0,0,0">
                <StackPanel Margin="28,0,28,28">

                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding NoSchedule, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" Margin="0,80,0,0">
                        <TextBlock Text="📡" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="NO SHOWS SCHEDULED" FontFamily="Consolas"
                                   FontSize="14" Foreground="#333344"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Add videos in the Schedule manager to see them here."
                                   FontFamily="Consolas" FontSize="11" Foreground="#2A2A3A"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Days -->
                    <ItemsControl ItemsSource="{Binding ScheduleDays}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,24">

                                    <!-- Date header -->
                                    <Border Margin="0,0,0,10" Padding="0,0,0,8"
                                            BorderBrush="#1A1A28" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#E8312A" CornerRadius="2"
                                                    Padding="6,2" Margin="0,0,10,0"
                                                    Visibility="{Binding IsToday,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="LIVE" FontFamily="Consolas"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding DateLabel}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       FontWeight="Bold" Foreground="#9999AA"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Shows for this day -->
                                    <ItemsControl ItemsSource="{Binding Shows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,4">

                                                    <!-- Show row -->
                                                    <Border CornerRadius="6" Padding="14,10"
                                                            BorderThickness="1" Margin="0,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#161622"/>
                                                                <Setter Property="BorderBrush"  Value="#2A2A3A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNow}" Value="True">
                                                                        <Setter Property="Background" Value="#1A0A0A"/>
                                                                        <Setter Property="BorderBrush"  Value="#E8312A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="110"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Time -->
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TimeRange}"
                                                                           FontFamily="Consolas" FontSize="12"
                                                                           Foreground="#9999AA"/>
                                                                <Border Background="#E8312A" CornerRadius="2"
                                                                        Padding="4,1" Margin="0,3,0,0"
                                                                        HorizontalAlignment="Left"
                                                                        Visibility="{Binding IsNow,
                                                                            Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="ON AIR NOW"
                                                                               FontFamily="Consolas" FontSize="8"
                                                                               FontWeight="Bold" Foreground="White"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <!-- Title -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Title}"
                                                                       FontFamily="Consolas" FontSize="14"
                                                                       FontWeight="Bold" Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Show Duration -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding ShowDuration}"
                                                                       FontFamily="Consolas" FontSize="12"
                                                                       Foreground="#9999AA"
                                                                       VerticalAlignment="Center"/>

                                                            <!-- Ad Time -->
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding AdTime}"
                                                                       FontFamily="Consolas" FontSize="12"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#555566"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasAds}" Value="True">
                                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <!-- True End -->
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding TrueEndTime}"
                                                                       FontFamily="Consolas" FontSize="12"
                                                                       Foreground="#9999AA"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Commercial break sub-rows -->
                                                    <ItemsControl ItemsSource="{Binding Breaks}"
                                                                  Visibility="{Binding HasAds,
                                                                      Converter={StaticResource BoolToVis}}"
                                                                  Margin="20,0,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#0D0D1A"
                                                                        BorderBrush="#1A1A28"
                                                                        BorderThickness="0,0,0,1"
                                                                        Padding="12,6">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="100"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="100"/>
                                                                            <ColumnDefinition Width="190"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding Offset}"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   Foreground="#E8312A"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Title}"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   Foreground="#CCCCCC"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Duration}"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   Foreground="#F0A500"/>
                                                                        <TextBlock Grid.Column="3"
                                                                                   Text="{Binding EndsAt}"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   Foreground="#555566"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
