<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.CommercialLibrary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commercial Library"
        Height="520" Width="820"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="COMMERCIAL LIBRARY"
                   Foreground="White" FontSize="28" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="+ Add Files"
                    Command="{Binding AddFilesCommand}"
                    Background="#378ADD" Foreground="White"
                    BorderThickness="0" Padding="12,6" FontSize="13"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="+ Add Folder"
                    Command="{Binding AddFolderCommand}"
                    Background="#2A6A2A" Foreground="White"
                    BorderThickness="0" Padding="12,6" FontSize="13"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Remove Selected"
                    Command="{Binding RemoveCommercialCommand}"
                    IsEnabled="{Binding SelectedCommercial,
                                Converter={StaticResource NullToBoolConverter}}"
                    Background="#CC3333" Foreground="White"
                    BorderThickness="0" Padding="12,6" FontSize="13"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Commercial list — Weight column is editable inline -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Commercials}"
                  SelectedItem="{Binding SelectedCommercial, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  FontSize="14" RowHeight="34"
                  GridLinesVisibility="Horizontal"
                  
                  BorderThickness="0">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Title"
                                    Binding="{Binding Title}"
                                    IsReadOnly="True" Width="*"/>

                <DataGridTextColumn Header="Duration"
                                    Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}"
                                    IsReadOnly="True" Width="90"/>

                <!-- Weight is editable directly in the grid -->
                <DataGridTemplateColumn Header="Weight (1–10)" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Weight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <Slider Minimum="1" Maximum="10"
                                    Value="{Binding Weight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" Margin="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="File Path"
                                    Binding="{Binding FilePath}"
                                    IsReadOnly="True" Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status + Save Weights -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       Foreground="#9999AA" FontSize="12"
                       VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1"
                         IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                         Width="120" Height="6" Margin="0,0,12,0"/>
            <Button Grid.Column="2"
                    Content="Save Weights"
                    Command="{Binding SaveCommand}"
                    Background="#378ADD" Foreground="White"
                    BorderThickness="0" Padding="10,4" FontSize="12"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
