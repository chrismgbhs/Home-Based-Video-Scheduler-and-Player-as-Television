<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Home_Based_Video_Scheduler_and_Player_as_Television.Converters"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <!-- Fade IN: 0 -> 1 over 600ms -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6"
                             EasingFunction="{x:Null}"/>
        </Storyboard>

        <!-- Fade OUT: 1 -> 0 over 800ms -->
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.8"/>
        </Storyboard>

        <!-- Title slide-in from left: translates X from -30 to 0 while fading in -->
        <Storyboard x:Key="TitleSlideIn">
            <DoubleAnimation Storyboard.TargetName="TitleTranslate"
                             Storyboard.TargetProperty="X"
                             From="-30" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TitlePanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <!-- Up Next slide-in from left -->
        <Storyboard x:Key="UpNextSlideIn">
            <DoubleAnimation Storyboard.TargetName="UpNextTranslate"
                             Storyboard.TargetProperty="X"
                             From="-20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="UpNextPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4"/>
        </Storyboard>

        <!-- Up Next fade out -->
        <Storyboard x:Key="UpNextFadeOut">
            <DoubleAnimation Storyboard.TargetName="UpNextPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.6"/>
        </Storyboard>
    </Window.Resources>

    <Grid IsHitTestVisible="False"
          Visibility="{Binding IsOverlayVisible, Converter={StaticResource BoolToVis}}">

        <!-- TOP-LEFT: Show title + clock underneath -->
        <StackPanel x:Name="TitlePanel"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="36,36,0,0" Opacity="0">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="TitleTranslate"/>
            </StackPanel.RenderTransform>

            <!-- Show title — large, no "NOW PLAYING" label -->
            <TextBlock x:Name="TitleText"
                       Text="{Binding NowPlaying}"
                       Foreground="White" FontSize="26" FontWeight="Bold"
                       Effect="{x:Null}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Clock underneath the title -->
            <TextBlock Text="{Binding ClockText}"
                       Foreground="#CCCCCC" FontSize="15" FontWeight="Normal"
                       Margin="0,4,0,0"
                       Visibility="{Binding ClockText, Converter={StaticResource StringToVis}}"/>
        </StackPanel>

        <!-- TOP-LEFT (below title): Up Next — slides in, then fades out -->
        <StackPanel x:Name="UpNextPanel"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="36,110,0,0" Opacity="0">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="UpNextTranslate"/>
            </StackPanel.RenderTransform>

            <Border Background="#AA000000" CornerRadius="4" Padding="10,5"
                    Visibility="{Binding UpNext, Converter={StaticResource StringToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="UP NEXT  " Foreground="#999999"
                               FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UpNext}"
                               Foreground="White" FontSize="13"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- TOP-RIGHT: Channel logo — fades out after 5s -->
        <Image x:Name="LogoImage"
               Source="{Binding LogoImage}"
               Height="80" Margin="0,24,36,0"
               HorizontalAlignment="Right" VerticalAlignment="Top"
               Opacity="0"/>

    </Grid>
</Window>
