<Window x:Class="Home_Based_Video_Scheduler_and_Player_as_Television.Views.Player"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Home_Based_Video_Scheduler_and_Player_as_Television.Views"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        Background="Black">

    <Grid>
        <!-- Video Output -->
        <vlc:VideoView MediaPlayer="{Binding MediaPlayer}" />

        <!-- Overlay Layer (TV-style UI) -->
        <Grid IsHitTestVisible="False">

            <!-- Now Playing (Top Left) -->
            <TextBlock Text="{Binding NowPlaying}"
                       Margin="15"
                       VerticalAlignment="Top"
                       Foreground="White"
                       FontSize="18"
                       Background="#66000000"
                       Padding="5"/>

            <!-- Logo (Top Right) -->
            <Image Source="{Binding LogoPath}"
                   Width="100"
                   Height="50"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="15"
                   Opacity="0.8"/>

            <!-- Subtitle area (LibVLC renders internally, this is optional fallback UI) -->
        </Grid>
    </Grid>
</Window>
